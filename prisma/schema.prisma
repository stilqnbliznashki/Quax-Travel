// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum PlaceCategory {
  HOTEL
  RESTAURANT
  ATTRACTION
}

model Destination {
  id         String            @id @default(cuid())
  name       String
  country    String
  summary    String
  currency   String
  language   String
  bestSeason String
  emergency  String
  latitude   Float
  longitude  Float
  places     Place[]
  weather    WeatherSnapshot[]
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
}

model Place {
  id            String        @id @default(cuid())
  slug          String        @unique
  name          String
  category      PlaceCategory
  shortSummary  String
  description   String
  address       String
  neighborhood  String
  priceHint     String
  rating        Float
  imageUrl      String?
  latitude      Float
  longitude     Float
  destinationId String
  destination   Destination   @relation(fields: [destinationId], references: [id], onDelete: Cascade)
  offers        Offer[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([category])
  @@index([rating])
}

model Offer {
  id          String    @id @default(cuid())
  title       String
  description String
  priceLabel  String
  validUntil  DateTime?
  placeId     String
  place       Place     @relation(fields: [placeId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
}

model WeatherSnapshot {
  id            String      @id @default(cuid())
  date          DateTime
  condition     String
  temperatureC  Int
  destinationId String
  destination   Destination @relation(fields: [destinationId], references: [id], onDelete: Cascade)
}
